  \u201Cprivacy\u201C: {
    \u201Ceyebrow\u201C: \u201CRechtliches\u201C,
    \u201Ctitle\u201C: \u201CDatenschutzerklärung\u201C,
    \u201ClastUpdated\u201C: \u201CZuletzt aktualisiert: 29. März 2026\u201C,
    \u201Csections\u201C: {
      \u201Ccontroller\u201C: \u201CVerantwortlicher\u201C,
      \u201CgeneralInfo\u201C: \u201CAllgemeine Hinweise zur Datenverarbeitung\u201C,
      \u201CgeneralInfoText\u201C: \u201CWir verarbeiten personenbezogene Daten nur, soweit dies zur Bereitstellung einer funktionsfähigen Website, zur Beantwortung von Anfragen, zur Darstellung unserer Leistungen sowie zur sicheren und effizienten Durchführung unserer Geschäftskommunikation erforderlich ist.\u201C,
      \u201CgeneralInfoText2\u201C: \u201CDie Verarbeitung erfolgt in Übereinstimmung mit der Datenschutz-Grundverordnung (DSGVO) und den geltenden deutschen Datenschutzgesetzen.\u201C,
      \u201CgeneralInfoText3\u201C: \u201CPersonenbezogene Daten werden nicht an Dritte weitergegeben, es sei denn, dies ist für den technischen Betrieb der Website, die Vertragserfüllung oder vorvertragliche Maßnahmen, die Einhaltung gesetzlicher Verpflichtungen, auf Grundlage Ihrer Einwilligung oder auf anderer gesetzlicher Grundlage erforderlich.\u201C,
      \u201ClegalBases\u201C: \u201CRechtsgrundlagen der Verarbeitung\u201C,
      \u201ClegalBasesIntro\u201C: \u201CBei der Verarbeitung personenbezogener Daten stützen wir uns insbesondere auf folgende Rechtsgrundlagen:\u201C,
      \u201ClegalBasesList\u201C: [
        \u201CArt. 6 Abs. 1 lit. a DSGVO: Einwilligung\u201C,
        \u201CArt. 6 Abs. 1 lit. b DSGVO: Vertragserfüllung oder vorvertragliche Maßnahmen\u201C,
        \u201CArt. 6 Abs. 1 lit. c DSGVO: Erfüllung einer rechtlichen Verpflichtung\u201C,
        \u201CArt. 6 Abs. 1 lit. f DSGVO: Berechtigte Interessen\u201C
      ],
      \u201ClegalBasesNote\u201C: \u201CSoweit die Verarbeitung auf Art. 6 Abs. 1 lit. f DSGVO beruht, liegen unsere berechtigten Interessen im sicheren, stabilen, effizienten und nutzerorientierten Betrieb unserer Website, in der professionellen Darstellung unseres Unternehmens sowie in unserer Geschäftskommunikation.\u201C,
      \u201CserverLogs\u201C: \u201CWebsite-Zugriffsdaten und Server-Logfiles\u201C,
      \u201CserverLogsIntro\u201C: \u201CBeim Zugriff auf unsere Website werden automatisch Informationen durch unseren Hosting-Anbieter in sogenannten Server-Logfiles erfasst. Dies kann umfassen:\u201C,
      \u201CserverLogsList\u201C: [
        \u201CIP-Adresse\u201C,
        \u201CDatum und Uhrzeit des Zugriffs\u201C,
        \u201CAngeforderte Inhalte\u201C,
        \u201CZugriffsstatus und HTTP-Statuscode\u201C,
        \u201CÜbertragene Datenmenge\u201C,
        \u201CReferrer-URL\u201C,
        \u201CBrowsertyp und -version\u201C,
        \u201CBetriebssystem\u201C
      ],
      \u201CserverLogsNote\u201C: \u201CDiese Daten werden verarbeitet, um die Stabilität, Sicherheit und technische Funktionsfähigkeit der Website zu gewährleisten sowie um Missbrauch und sicherheitsrelevante Vorfälle zu erkennen, zu verhindern und zu untersuchen.\u201C,
      \u201CserverLogsLegal\u201C: \u201CRechtsgrundlage: Art. 6 Abs. 1 lit. f DSGVO.\u201C,
      \u201CserverLogsRetention\u201C: \u201CServer-Logdaten werden in der Regel für maximal 7 Tage gespeichert, es sei denn, eine längere Aufbewahrung ist zur Untersuchung sicherheitsrelevanter Vorfälle oder zur Geltendmachung, Ausübung oder Verteidigung von Rechtsansprüchen erforderlich.\u201C,
      \u201CcontactForm\u201C: \u201CKontaktaufnahme per E-Mail oder Kontaktformular\u201C,
      \u201CcontactFormText\u201C: \u201CWenn Sie uns per E-Mail kontaktieren oder eine Anfrage über unser Kontaktformular stellen, verarbeiten wir die von Ihnen bereitgestellten personenbezogenen Daten zum Zweck der Bearbeitung Ihrer Anfrage und der Kommunikation mit Ihnen.\u201C,
      \u201CcontactFormDataIntro\u201C: \u201CDies kann insbesondere folgende Daten umfassen:\u201C,
      \u201CcontactFormDataList\u201C: [
        \u201CVorname\u201C,
        \u201CNachname\u201C,
        \u201Cgeschäftliche E-Mail-Adresse\u201C,
        \u201CFirmenname\u201C,
        \u201CTelefonnummer, sofern freiwillig angegeben\u201C,
        \u201CProjekt- oder Anwendungsinformationen\u201C,
        \u201CNachrichteninhalt\u201C
      ],
      \u201CcontactFormRequired\u201C: \u201CPflichtfelder im Kontaktformular sind entsprechend gekennzeichnet. Diese Daten sind erforderlich, um Ihre Anfrage bearbeiten zu können.\u201C,
      \u201CcontactFormLegal\u201C: \u201CRechtsgrundlage:\u201C,
      \u201CcontactFormLegalList\u201C: [
        \u201CArt. 6 Abs. 1 lit. b DSGVO, wenn sich Ihre Anfrage auf vorvertragliche Maßnahmen oder die Vertragserfüllung bezieht\u201C,
        \u201CArt. 6 Abs. 1 lit. f DSGVO für allgemeine geschäftliche Kommunikation und sonstige Anfragen\u201C
      ],
      \u201CcontactFormNote\u201C: \u201CIhre Daten werden nicht an Dritte weitergegeben, es sei denn, dies ist zur Bearbeitung Ihrer Anfrage erforderlich, gesetzlich vorgeschrieben oder anderweitig rechtlich zulässig.\u201C,
      \u201CcontactFormRetention\u201C: \u201CWir speichern Ihre Anfrage nur so lange, wie dies zur Bearbeitung erforderlich ist. Soweit gesetzliche Aufbewahrungspflichten bestehen, erfolgt eine Speicherung für die gesetzlich vorgeschriebene Dauer.\u201C,
      \u201CprovisionOfData\u201C: \u201CBereitstellung personenbezogener Daten\u201C,
      \u201CprovisionOfDataText\u201C: \u201CDie Bereitstellung personenbezogener Daten ist weder gesetzlich noch vertraglich vorgeschrieben. Bestimmte Angaben können jedoch erforderlich sein, um Ihre Anfrage zu bearbeiten. Ohne diese Daten können wir Ihre Anfrage möglicherweise nicht bearbeiten.\u201C,
      \u201Chosting\u201C: \u201CHosting\u201C,
      \u201ChostingIntro\u201C: \u201CDiese Website wird gehostet von:\u201C,
      \u201ChostingNote\u201C: \u201CHetzner Online GmbH verarbeitet personenbezogene Daten in unserem Auftrag auf Grundlage eines Auftragsverarbeitungsvertrags gemäß Art. 28 DSGVO. Die Datenverarbeitung erfolgt auf Servern in Nürnberg, Deutschland.\u201C,
      \u201Ccookies\u201C: \u201CCookies\u201C,
      \u201CcookiesText\u201C: \u201CDiese Website verwendet ausschließlich technisch notwendige Cookies, die für den sicheren und ordnungsgemäßen Betrieb der Website erforderlich sind.\u201C,
      \u201CcookiesText2\u201C: \u201CEs werden keine Marketing-, Profiling-, Analyse- oder Werbetracking-Technologien eingesetzt.\u201C,
      \u201CcookiesLegal\u201C: \u201CRechtsgrundlage: Art. 6 Abs. 1 lit. f DSGVO. Unser berechtigtes Interesse liegt in der sicheren und effizienten Bereitstellung unserer Website.\u201C,
      \u201CdataRetention\u201C: \u201CDatenspeicherung\u201C,
      \u201CdataRetentionText\u201C: \u201CPersonenbezogene Daten werden nur so lange gespeichert, wie dies für den jeweiligen Verarbeitungszweck erforderlich ist oder gesetzliche Aufbewahrungsfristen nach deutschem Recht dies verlangen.\u201C,
      \u201CdataRetentionText2\u201C: \u201CGeschäftskorrespondenz kann gemäß den geltenden handels- und steuerrechtlichen Aufbewahrungspflichten aufbewahrt werden.\u201C,
      \u201CdataSecurity\u201C: \u201CDatensicherheit\u201C,
      \u201CdataSecurityText\u201C: \u201CWir setzen geeignete technische und organisatorische Maßnahmen ein, um personenbezogene Daten gegen zufällige oder unrechtmäßige Zerstörung, Verlust, Veränderung, unbefugte Offenlegung oder unbefugten Zugang zu schützen.\u201C,
      \u201CdataSecurityText2\u201C: \u201CDie Datenübertragung zwischen Ihrem Browser und unserer Website wird mittels SSL- bzw. TLS-Technologie verschlüsselt.\u201C,
      \u201CyourRights\u201C: \u201CIhre Rechte\u201C,
      \u201CyourRightsIntro\u201C: \u201CSie haben nach der DSGVO folgende Rechte:\u201C,
      \u201CyourRightsList\u201C: [
        \u201CAuskunftsrecht gemäß Art. 15 DSGVO\u201C,
        \u201CRecht auf Berichtigung gemäß Art. 16 DSGVO\u201C,
        \u201CRecht auf Löschung gemäß Art. 17 DSGVO\u201C,
        \u201CRecht auf Einschränkung der Verarbeitung gemäß Art. 18 DSGVO\u201C,
        \u201CRecht auf Datenübertragbarkeit gemäß Art. 20 DSGVO\u201C,
        \u201CWiderspruchsrecht gemäß Art. 21 DSGVO\u201C,
        \u201CRecht auf Widerruf der Einwilligung jederzeit gemäß Art. 7 Abs. 3 DSGVO\u201C
      ],
      \u201CyourRightsNote\u201C: \u201CSoweit personenbezogene Daten auf Grundlage von Art. 6 Abs. 1 lit. f DSGVO verarbeitet werden, haben Sie jederzeit das Recht, aus Gründen, die sich aus Ihrer besonderen Situation ergeben, Widerspruch einzulegen.\u201C,
      \u201CsupervisoryAuthority\u201C: \u201CAufsichtsbehörde\u201C,
      \u201CsupervisoryAuthorityText\u201C: \u201CWenn Sie der Auffassung sind, dass die Verarbeitung Ihrer personenbezogenen Daten gegen geltendes Datenschutzrecht verstößt, haben Sie das Recht, sich bei einer Aufsichtsbehörde zu beschweren.\u201C,
      \u201CsupervisoryAuthorityCompetent\u201C: \u201CDie zuständige Aufsichtsbehörde für die Deepvac GmbH ist:\u201C,
      \u201CnoAutomatedDecisionMaking\u201C: \u201CKeine automatisierte Entscheidungsfindung\u201C,
      \u201CnoAutomatedDecisionMakingText\u201C: \u201CWir verwenden im Zusammenhang mit dieser Website keine automatisierte Entscheidungsfindung einschließlich Profiling im Sinne von Art. 22 DSGVO.\u201C,
      \u201Cchanges\u201C: \u201CÄnderungen dieser Datenschutzerklärung\u201C,
      \u201CchangesText\u201C: \u201CWir behalten uns vor, diese Datenschutzerklärung zu aktualisieren, um Änderungen der Rechtslage oder Änderungen unserer Website oder unserer Leistungen zu berücksichtigen. Es gilt die jeweils auf unserer Website veröffentlichte Fassung.\u201C
    }
  },
